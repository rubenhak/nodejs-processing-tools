{
  "name": "processing-tools",
  "version": "2.0.1",
  "description": "Library contains variety of tools to help with data processing.",
  "main": "dist/index.js",
  "types": "dist",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "env TS_NODE_COMPILER_OPTIONS='{\"module\": \"commonjs\" }' mocha -r ts-node/register 'test/**/*.ts'",
    "format": "prettier --write ./src/ ./test/",
    "format-check": "prettier --check ./src/ ./test/",
    "lint": "eslint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubenhak/nodejs-processing-tools.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/rubenhak/nodejs-processing-tools/issues"
  },
  "homepage": "https://github.com/rubenhak/nodejs-processing-tools#readme",
  "dependencies": {
    "date-diff": "1.0.2",
    "ip": "2.0.1",
    "pretty-ms": "^9.3.0",
    "shelljs": "0.10.0",
    "the-lodash": "^3.0.3",
    "the-promise": "^3.0.1",
    "toposort": "2.0.2",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "mocha": "^11.7.6",
    "prettier": "^3.9.4",
    "should": "^13.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "the-lodash": "^3.0.3",
      "the-promise": "^3.0.1"
    }
  }
}
